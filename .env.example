# NovixWork — sao chép file này thành .env rồi điền giá trị từ Supabase project
# (Supabase Dashboard → Project Settings → API). Chỉ dùng anon key ở frontend.
# Bỏ trống 2 biến này => app chạy chế độ prototype in-memory (demo/UAT).

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...
